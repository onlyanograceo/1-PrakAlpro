    "    faktorial = 1\n",
    "    for j in range(1, i + 1):\n",
    "        faktorial *= j\n",
    "    \n",
    "    # tampilkan faktorial\n",
    "    print(faktorial, end=\" \")\n",
    "    \n",
    "    # tampilkan deret menurun dari i ke 1\n",
    "    for k in range(i, 0, -1):\n",
    "        print(k, end=\" \")\n",
    "    \n",
    "    print()  # pindah baris"
