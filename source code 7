    "def is_prima(x):\n",
    "    if x < 2:\n",
    "        return False\n",
    "    for i in range(2, int(x**0.5) + 1):\n",
    "        if x % i == 0:\n",
    "            return False\n",
    "    return True\n",
    "\n",
    "n = int(input(\"Masukkan nilai n: \"))\n",
    "\n",
    "for i in range(n - 1, 1, -1):\n",
    "    if is_prima(i):\n",
    "        print(\"Bilangan prima terdekat < {} adalah {}\".format(n, i))\n",
    "        break\n",
    "else:\n",
    "    print(\"Tidak ada bilangan prima yang lebih kecil dari\", n)"
   ]
